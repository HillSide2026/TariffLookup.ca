# TariffLookup.ca environment template
#
# Copy this file to `.env` when local runtime configuration is needed.
# Keep secrets out of git.
#
# This template is intentionally stack-agnostic until frontend/backend
# scaffolding and hosting choices are finalized.

# Runtime
APP_ENV=development
APP_NAME=TariffLookup

# Local URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Data paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
NORMALIZED_DATA_DIR=./data/normalized

# Database
# Set once the persistence layer is selected.
# DATABASE_URL=

# Auth
# Set once user authentication is added.
# AUTH_SECRET=

# Analytics / monitoring
# Add only if instrumentation is introduced.
# ANALYTICS_KEY=
# ERROR_REPORTING_DSN=

# External tariff-data providers
# Add provider credentials here only if the MVP uses paid or authenticated
# tariff/agreement data sources.
# TARIFF_DATA_API_KEY=
