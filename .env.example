# TariffLookup.ca environment template
#
# Copy this file to `.env` when local runtime configuration is needed.
# Keep secrets out of git.

# Application
APP_ENV=development
APP_NAME=TariffLookup
LOG_LEVEL=info

# Local URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
# ALLOWED_ORIGINS=http://localhost:3000,https://tarifflookup-ca-staging.vercel.app

# Backend runtime
HOST=0.0.0.0
PORT=8000

# Data paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
NORMALIZED_DATA_DIR=./data/normalized

# Supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Monitoring thresholds
MONITORING_WINDOW_MINUTES=15
MONITORING_LOOKUP_ERROR_RATE_THRESHOLD=0.30
MONITORING_AUTH_FAILURE_RATE_THRESHOLD=0.50
MONITORING_HISTORY_API_FAILURE_RATE_THRESHOLD=0.30
MONITORING_CONSECUTIVE_5XX_THRESHOLD=3

# Staging smoke test
# STAGING_FRONTEND_URL=
# STAGING_API_BASE_URL=
# STAGING_SUPABASE_URL=
# STAGING_SUPABASE_ANON_KEY=
# STAGING_TEST_EMAIL=
# STAGING_TEST_PASSWORD=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional AI or explanation layer
# OPENAI_API_KEY=

# External tariff-data providers
# TARIFF_DATA_API_KEY=
# TARIFF_DATA_BASE_URL=
