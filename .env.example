# TariffLookup.ca environment template
#
# Copy this file to `.env` when local runtime configuration is needed.
# Keep secrets out of git.

# Application
APP_ENV=development
APP_NAME=TariffLookup

# Local URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Backend runtime
HOST=0.0.0.0
PORT=8000

# Data paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
NORMALIZED_DATA_DIR=./data/normalized

# Supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional AI or explanation layer
# OPENAI_API_KEY=

# External tariff-data providers
# TARIFF_DATA_API_KEY=
# TARIFF_DATA_BASE_URL=
