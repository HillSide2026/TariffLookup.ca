{
  "name": "tarifflookup-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "intake:eu": "npm run build && node dist/scripts/intake-eu-source-batch.js",
    "normalize:eu": "npm run build && node dist/scripts/normalize-eu-source.js",
    "generate:eu-docs": "npm run build && node dist/scripts/generate-eu-coverage-docs.js",
    "check:eu-docs": "npm run build && node dist/scripts/generate-eu-coverage-docs.js --check"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
