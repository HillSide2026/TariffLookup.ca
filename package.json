{
  "name": "tarifflookup-ca",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "test": "npm run test:backend && npm run test:frontend",
    "intake:eu": "npm --prefix backend run intake:eu --",
    "normalize:eu": "npm --prefix backend run normalize:eu --",
    "check:env:backend": "node scripts/verify-env.mjs backend",
    "check:env:frontend": "node scripts/verify-env.mjs frontend",
    "check:env:staging": "node scripts/verify-env.mjs staging",
    "verify:release": "npm run test && npm run build:backend && npm run build:frontend",
    "smoke:staging": "node scripts/smoke-staging.mjs"
  }
}
